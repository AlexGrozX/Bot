# ─────────────────────────────────────────────
#  IVB Bot Configuration
# ─────────────────────────────────────────────

# Bloomberg Terminal (Desktop API — connects via BBComm on localhost:8194)
BLOOMBERG_HOST=localhost
BLOOMBERG_PORT=8194

# Polymarket Credentials
POLY_API_KEY=019d5525-ad6d-73fb-9112-f4495ae8af8f
POLY_ADDRESS=0xeb2999b9e4b867614b0510f7f4b9b0d3880347c9
POLY_PRIVATE_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_CHAIN_ID=137

# IVB Model Parameters
# Instruments to monitor (Bloomberg tickers)
INSTRUMENTS=XBT Curncy,ES1 Index,NQ1 Index,SPX Index

# Volume breakout threshold (multiplier over rolling average)
VOLUME_BREAKOUT_MULTIPLIER=3.0

# Minimum volume delta imbalance to confirm aggression (%)
MIN_DELTA_IMBALANCE=60.0

# Balance detection: lookback bars for value area
BALANCE_LOOKBACK_BARS=48

# Value Area percentage (standard = 70%)
VALUE_AREA_PCT=0.70

# Low Volume Node threshold (% of max volume at price level)
LVN_THRESHOLD=0.20

# Risk Management
BANKROLL_USDC=400.0
MAX_KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.10
DAILY_LOSS_LIMIT_PCT=0.05

# Bar interval for intraday analysis (minutes)
BAR_INTERVAL=5

# Session times (ET)
NY_SESSION_START=09:30
NY_SESSION_END=16:00
LONDON_SESSION_START=03:00
LONDON_SESSION_END=08:30

# Dashboard refresh rate (seconds)
DASHBOARD_REFRESH=1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ivb_bot.log
